// Brewline — database schema
//
// One canonical model per domain entity; the client- and server-
// side stores are thin caches on top of these tables. See
// `prisma/seed.ts` for representative data.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// Connection URL lives in `prisma.config.ts` (Prisma 7 requirement);
// runtime clients pass an adapter — see `src/lib/prisma.ts`.
datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────
// Identity & access
// ──────────────────────────────────────────────────────────────

/// Workspace role. Replaces what used to be a hardcoded enum so
/// custom roles can be created from Settings → Roles. The four
/// built-ins (admin / manager / cashier / kitchen) are seeded at
/// boot with `isSystem: true` so they can't be deleted.
model Role {
  /// Stable slug ("admin", "manager", "headChef", …). Used as the
  /// foreign key on `User.role` so existing string comparisons keep
  /// working unchanged.
  id           String   @id
  /// Display name shown in role badges and dropdowns.
  name         String
  description  String?
  /// JSON array of permission strings (see `Permission` in
  /// `src/types/auth.ts`). DB-driven so custom roles can mix and
  /// match without a code change.
  permissions  Json
  /// Built-in roles are guarded against deletion + slug edits so the
  /// onboarding flow can rely on them existing.
  isSystem     Boolean  @default(false)
  /// Optional role-level landing route. Falls back to /pos when null.
  defaultRoute String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  phone        String?
  passwordHash String
  /// Role slug. Foreign key into `Role.id`; user creation flows must
  /// ensure the slug exists (handled by `ensureBuiltInRoles()`).
  role         String
  roleRef      Role         @relation(fields: [role], references: [id])
  avatar       String?
  /// Optional per-user landing route. When unset we fall back to the
  /// role's `defaultRoute`, then to /pos.
  defaultRoute String?
  /// Gross monthly salary in workspace currency (Rs). Null = unset.
  monthlySalary Decimal?    @db.Decimal(10, 2)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  sessions     Session[]
  orders       Order[]
  shifts       Shift[]
  attendance   Attendance[]
  pushSubscriptions PushSubscription[]

  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/// One Web Push subscription per device the user has opted into
/// notifications from. `endpoint` is globally unique (it's the URL
/// the push service issued for this device); we use it as the
/// natural key for upserts so re-subscribing on the same device
/// updates the row rather than duplicating it.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

/// A team member added before being granted access. The Staff page
/// creates these (name + email only). Settings → Team turns one into
/// a real `User` by attaching a role + password; the draft is then
/// deleted in the same transaction.
model PendingMember {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────
// Payment channels (cashbook accounts)
// ──────────────────────────────────────────────────────────────

/// A configurable money channel — Cash drawer, wallet (EasyPaisa,
/// JazzCash), or bank account. Each one tracks an opening balance
/// and a running current balance; the current is mutated atomically
/// by transfers (and, in a future iteration, by sales and supplier
/// payouts).
///
/// Named `PaymentChannel` at the DB layer to keep the `PaymentMethod`
/// enum (Order.payment) unambiguous — the UI still calls these
/// "Payment Methods" since that's the operator's mental model.
model PaymentChannel {
  id             String             @id @default(cuid())
  name           String             @unique
  /// Maps the channel to one of the `PaymentMethod` enum values used
  /// on `Order.payment`. Drives the icon shown in the POS take-payment
  /// dialog and the kind reported to BRA fiscalization.
  kind           PaymentMethod      @default(cash)
  openingBalance Decimal            @db.Decimal(14, 2)
  currentBalance Decimal            @db.Decimal(14, 2)
  archived       Boolean            @default(false)
  archivedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  outgoing       PaymentTransfer[]  @relation("transferFrom")
  incoming       PaymentTransfer[]  @relation("transferTo")
}

/// A money movement from one channel to another. The
/// `createTransferAction` server action wraps `from -= amount`,
/// `to += amount`, and this row in a single transaction so balances
/// can never drift.
model PaymentTransfer {
  id         String         @id @default(cuid())
  fromId     String
  from       PaymentChannel @relation("transferFrom", fields: [fromId], references: [id])
  toId       String
  to         PaymentChannel @relation("transferTo", fields: [toId], references: [id])
  amount     Decimal        @db.Decimal(14, 2)
  occurredAt DateTime
  note       String?
  createdAt  DateTime       @default(now())

  @@index([occurredAt])
  @@index([fromId])
  @@index([toId])
}

// ──────────────────────────────────────────────────────────────
// Menu & kitchen routing
// ──────────────────────────────────────────────────────────────

model KitchenStation {
  id        String          @id @default(cuid())
  name      String          @unique
  printer   String?
  active    Boolean         @default(true)
  color     String          @default("#6F4E37")
  menuItems MenuItem[]
  tickets   KitchenTicket[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model MenuCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  color     String
  items     MenuItem[]
  createdAt DateTime   @default(now())
}

model MenuItem {
  id              String             @id @default(cuid())
  name            String
  description     String?
  price           Decimal            @db.Decimal(10, 2)
  sku             String?            @unique
  /// Pakistan Customs Tariff code reported per line item to BRA.
  /// Falls back to FiscalConfig.defaultPctCode at submission time.
  pctCode         String?
  available       Boolean            @default(true)
  posVisible      Boolean            @default(true)
  popular         Boolean            @default(false)
  prepTimeMinutes Int?
  image           String?
  categoryId      String
  category        MenuCategory       @relation(fields: [categoryId], references: [id])
  stationId       String
  station         KitchenStation     @relation(fields: [stationId], references: [id])
  modifiers       Json?
  recipe          RecipeIngredient[]
  orderItems      OrderItem[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([categoryId])
  @@index([stationId])
}

// ──────────────────────────────────────────────────────────────
// Inventory (raw materials)
// ──────────────────────────────────────────────────────────────

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contact        String?
  email          String?
  phone          String?
  rating         Float           @default(0)
  inventoryItems InventoryItem[]
  createdAt      DateTime        @default(now())
}

model InventoryItem {
  id            String              @id @default(cuid())
  name          String
  sku           String              @unique
  category      String
  unit          String
  stock         Decimal             @db.Decimal(12, 3)
  reorderLevel  Decimal             @db.Decimal(12, 3)
  costPerUnit   Decimal             @db.Decimal(10, 4)
  supplierId    String?
  supplier      Supplier?           @relation(fields: [supplierId], references: [id])
  lastRestocked DateTime?
  expiresAt     DateTime?
  recipes       RecipeIngredient[]
  movements     InventoryMovement[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model RecipeIngredient {
  id              String        @id @default(cuid())
  menuItemId      String
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Decimal       @db.Decimal(10, 4)
  unit            String

  @@unique([menuItemId, inventoryItemId])
}

model InventoryMovement {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  delta           Decimal       @db.Decimal(12, 3) // negative for consumption, positive for restock
  reason          String
  orderId         String?
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId])
  @@index([orderId])
  /// `stockTrend7d` filters by `createdAt >= X AND delta < 0`. Single-
  /// column index on createdAt is plenty — the delta predicate prunes
  /// a small remainder after the date scan.
  @@index([createdAt])
}

// ──────────────────────────────────────────────────────────────
// Tables, orders, kitchen tickets
// ──────────────────────────────────────────────────────────────

model Table {
  id        String   @id @default(cuid())
  name      String   @unique
  capacity  Int
  occupancy Int      @default(0)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  pending
  preparing
  ready
  completed
  cancelled
  refunded
}

enum PaymentMethod {
  card
  cash
  wallet
  online
}

model Order {
  id            String          @id @default(cuid())
  number        String          @unique
  status        OrderStatus
  /// Free-text channel ("dine-in" / "takeaway" / "delivery" / "online").
  /// Kept as a string because "dine-in" can't appear in a Postgres enum.
  channel       String
  customerName  String?
  customerPhone String?
  buyerNtn      String?
  buyerCnic     String?
  tableId       String?
  table         Table?          @relation(fields: [tableId], references: [id])
  /// Party size for dine-in orders. Drives how many of the table's
  /// seats the order takes up. 1 by default; 0 for non-dine-in
  /// channels (the column is still required so totals stay simple).
  guests        Int             @default(1)
  staffId       String?
  staff         User?           @relation(fields: [staffId], references: [id], onDelete: SetNull)
  subtotal      Decimal         @db.Decimal(10, 2)
  tax           Decimal         @db.Decimal(10, 2)
  tip           Decimal?        @db.Decimal(10, 2)
  discount      Decimal?        @db.Decimal(10, 2)
  total         Decimal         @db.Decimal(10, 2)
  /// Nullable: held orders accumulate items + go to the kitchen long
  /// before the operator collects payment. `payment` and `paidAt` are
  /// both set in the same step via `payOrderAction`.
  payment       PaymentMethod?
  paidAt        DateTime?
  notes         String?
  /// BRA-issued fiscal invoice number. Populated after successful
  /// submission to the BRA Software Fiscal Device (local or cloud).
  fiscalInvoiceNumber String?
  fiscalSubmittedAt   DateTime?
  fiscalAttempts      Int       @default(0)
  fiscalLastError     String?
  fiscalSubmissions   FiscalSubmission[]
  items         OrderItem[]
  tickets       KitchenTicket[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([createdAt])
  /// Every analytics query filters by `paidAt >= X AND status NOT IN
  /// ('cancelled','refunded')`. Without this index the dashboard /
  /// reports KPIs sequentially scan the whole Order table on every
  /// page load.
  @@index([paidAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  /// Denormalized at the time of sale so historical orders stay legible
  /// even if the underlying menu item is renamed or deleted.
  name       String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  modifiers  Json?
  note       String?
  /// Stamped when this line item is finished by the kitchen — i.e.
  /// when the parent ticket first transitions to `ready`. Items
  /// inserted later (via `addItemsToHeldOrderAction`) land with
  /// `preparedAt: null` so the cook can distinguish fresh additions
  /// from already-completed work on a reopened ticket.
  preparedAt DateTime?

  @@index([orderId])
  /// `topProducts` + `categoryRevenue` group/join by menuItemId.
  /// Postgres doesn't auto-index FK columns, so without this Prisma
  /// scans the OrderItem table for every analytics roll-up.
  @@index([menuItemId])
}

enum TicketStatus {
  pending
  preparing
  ready
  served
  /// Set when the parent order is cancelled before payment. The
  /// kitchen surface keeps cancelled tickets visible (struck-out)
  /// until a cook explicitly dismisses them so prep can be stopped
  /// without surprises.
  cancelled
}

model KitchenTicket {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stationId String
  station   KitchenStation @relation(fields: [stationId], references: [id])
  status    TicketStatus   @default(pending)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([orderId, stationId])
  @@index([stationId, status])
}

// ──────────────────────────────────────────────────────────────
// BRA fiscal device integration
// ──────────────────────────────────────────────────────────────

enum FiscalMode {
  disabled
  local
  cloud
}

enum FiscalEnvironment {
  sandbox
  production
}

/// Workspace-wide configuration for invoice fiscalization with the
/// Balochistan Revenue Authority (BRA). A single row is enough — we
/// use a fixed primary key ("default") and upsert it on save.
///
/// `bearerToken` and `accessCode` are sensitive; never expose either
/// in client-bound payloads (the query helper strips them).
/// Workspace identity — name, location, currency, time zone, receipt
/// footer, operating hours. Singleton (`id = "default"`) seeded by
/// `ensureWorkspace()` on first onboarding and edited from
/// Settings → Workspace.
///
/// The four "Sun..Sat" hour pairs encode operating hours per day; an
/// empty/null pair means "closed that day". Kept on the Workspace
/// row (rather than a Hours table) because the UI works on the same
/// row in a single save.
model Workspace {
  id            String   @id @default("default")
  name          String   @default("My café")
  legalEntity   String?
  taxId         String?
  /// ISO-ish currency code. Drives downstream formatting helpers.
  currency      String   @default("PKR")
  /// IANA tz string, e.g. "Asia/Karachi".
  timezone      String   @default("Asia/Karachi")
  /// City the café operates in — captured during onboarding.
  city          String?
  /// Street-level address line, e.g. "123 Mission St". Surfaced in
  /// the sidebar when set, else falls back to `city`.
  addressLine   String?
  /// Footer line printed on each receipt.
  receiptFooter String?
  /// Thermal paper width in millimeters. "80" (standard café roll) or
  /// "58" (compact handheld roll). Drives every receipt + ticket
  /// layout — see `src/features/receipts/`.
  receiptWidth  String   @default("80")
  /// Per-day operating hours. Null = closed that day. Format "HH:mm".
  hoursMonOpen  String?  @default("06:30")
  hoursMonClose String?  @default("20:30")
  hoursTueOpen  String?  @default("06:30")
  hoursTueClose String?  @default("20:30")
  hoursWedOpen  String?  @default("06:30")
  hoursWedClose String?  @default("20:30")
  hoursThuOpen  String?  @default("06:30")
  hoursThuClose String?  @default("20:30")
  hoursFriOpen  String?  @default("06:30")
  hoursFriClose String?  @default("20:30")
  hoursSatOpen  String?  @default("06:30")
  hoursSatClose String?  @default("20:30")
  hoursSunOpen  String?  @default("06:30")
  hoursSunClose String?  @default("20:30")
  updatedAt     DateTime @updatedAt
}

/// Workspace-wide tax configuration. Singleton — the cart picks it up
/// on hydrate. `rate` is decimal (0.085 = 8.5%), `label` lets you say
/// "GST" / "Sales tax" / "VAT" instead of the default "Tax".
model TaxConfig {
  id        String   @id @default("default")
  rate      Float    @default(0.085)
  label     String   @default("Tax")
  updatedAt DateTime @updatedAt
}

model FiscalConfig {
  id             String            @id @default("default")
  enabled        Boolean           @default(false)
  mode           FiscalMode        @default(disabled)
  environment    FiscalEnvironment @default(sandbox)
  /// BRA-issued POS Registration Number (called POSID in the spec).
  posId          String?
  /// Access code paired with the POS ID; used for the local fiscal device.
  accessCode     String?
  /// Bearer token for the cloud endpoint (sandbox/production).
  bearerToken    String?
  /// Override for the local device URL. Default is the spec's `http://localhost:8524`.
  localBaseUrl   String            @default("http://localhost:8524")
  /// PCT (Pakistan Customs Tariff) code applied to any menu item
  /// that doesn't carry its own. BRA's documented placeholder is "00000000".
  defaultPctCode String            @default("00000000")
  /// Optional display-only metadata (helps operators sanity-check the config).
  businessName   String?
  bntn           String?
  /// Auto-submit invoices to BRA when a POS order is placed.
  /// When false, operators submit manually from the order detail drawer.
  autoSubmit     Boolean           @default(true)
  updatedAt      DateTime          @updatedAt
}

/// One row per submission attempt against the BRA fiscal device.
/// Keeps a forensic audit so failed submissions can be re-driven and
/// successful ones can be reconciled with BRA's portal later.
model FiscalSubmission {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  mode            FiscalMode
  environment     FiscalEnvironment
  endpoint        String
  /// Whether BRA accepted the invoice (Code == "100" in the spec).
  succeeded       Boolean
  /// Fiscal invoice number returned by BRA on success.
  fiscalInvoiceNumber String?
  /// Raw response code / message from BRA.
  responseCode    String?
  responseMessage String?
  errorMessage    String?
  /// Payload + response captured verbatim for debugging.
  requestBody     Json
  responseBody    Json?
  attemptedAt     DateTime @default(now())

  @@index([orderId])
  @@index([attemptedAt])
}

// ──────────────────────────────────────────────────────────────
// Activity audit log (recent events feed)
// ──────────────────────────────────────────────────────────────

enum ActivityType {
  order
  stock
  staff
  system
}

enum ShiftStatus {
  scheduled
  confirmed
  completed
  missed
}

/// A scheduled work block for one team member on one calendar day.
/// `start`/`end` are stored as ISO timestamps (in UTC) so we can do
/// time-based queries; the UI does the day-of-week + local-time
/// formatting.
model Shift {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime    @db.Date
  start     DateTime
  end       DateTime
  status    ShiftStatus @default(scheduled)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
  @@index([date])
}

enum AttendanceState {
  onTime
  late
  absent
}

/// One row per (user, day) recording how they showed up. The
/// dashboard rolls these up into the 7-day attendance chart.
model Attendance {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime        @db.Date
  state     AttendanceState
  minutesLate Int?
  createdAt DateTime        @default(now())

  @@unique([userId, date])
  @@index([date])
}

/// Append-only feed of operationally interesting events — order
/// placed/paid/cancelled, stock received, members invited, etc.
/// Powers the dashboard's "Recent activity" panel and lets us
/// reconstruct an at-a-glance timeline without trawling individual
/// tables.
model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String?
  /// Optional human-readable actor (cashier name) captured at write
  /// time so deleting a user later doesn't blank the audit log.
  actorName   String?
  actorId     String?
  /// Loose backrefs so we can deep-link or join when we need to.
  orderId     String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  @@index([createdAt])
  @@index([type])
}
